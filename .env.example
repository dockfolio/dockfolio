# Dockfolio Configuration
# Copy this to .env and fill in your values

# === Required ===
# None — Dockfolio works out of the box with Docker

# === Server ===
# PORT=3000
# NODE_ENV=production

# === Notifications (optional) ===
# Telegram bot for auto-healing alerts and system notifications
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# === Integrations (optional) ===
# Plausible Analytics — for traffic tracking
# PLAUSIBLE_URL=http://your-plausible:8000
# PLAUSIBLE_API_KEY=

# === Service URLs (optional) ===
# Override auto-detected service URLs
# UPTIME_KUMA_URL=http://uptime-kuma:3001
# BANNERFORGE_URL=http://bannerforge-container:3003/api/render
# DASHBOARD_URL=https://your-dashboard.example.com

# === GitHub Webhook (optional) ===
# Auto-deploy on push via GitHub webhook
# GITHUB_WEBHOOK_SECRET=

# === Database Paths (optional) ===
# Override default SQLite database locations
# AUTH_DB_PATH=/data/auth.db
# MARKETING_DB_PATH=/data/marketing.db
# BACKUP_DIR=/home/deploy/backups

# === Branding (optional) ===
# Customize email templates and branding
# BRAND_NAME=My Company
# BRAND_URL=https://example.com
# EMAIL_FROM_DOMAIN=example.com

# === Advanced ===
# VM_COST_MONTHLY=12.48
# EMAIL_OBFUSCATION_KEY=your-random-key
# DEBUG=true
